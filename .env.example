# Environment template for the backend API.
#
# Copy to backend/.env when running the server OUTSIDE Docker:
#   cp .env.example backend/.env
#
# Inside Docker these values are already set by docker-compose.yml, so this
# file is only needed for a bare `node index.js` run. Never commit real secrets.

# Redis connection string.
#   - Inside Docker:      redis://redis:6379   (service name on the compose network)
#   - Running on host:    redis://localhost:6379
REDIS_URL=redis://redis:6379

# Base URL of the Ollama instance (no trailing slash).
#   - Docker Desktop:     http://host.docker.internal:11434  (reaches Ollama on your host)
#   - A LAN machine:      http://<that-machine-ip>:11434
OLLAMA_URL=http://host.docker.internal:11434

# Port the Express server listens on.
PORT=3001
